// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 小说表
model Novel {
  id             String     @id @default(cuid())
  title          String
  description    String?
  descriptionOss String?    // 简介OSS路径
  cover          String?    // 封面图片URL
  coverOss       String?    // 封面图片OSS路径
  genre          String?    // 小说类型：玄幻、都市、科幻等
  status         String     @default("draft") // draft: 草稿, ongoing: 连载中, completed: 已完结
  wordCount      Int        @default(0) // 总字数
  outlineOss     String?    // 大纲OSS路径
  chapters       Chapter[]
  characters     Character[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("novels")
}

// 章节表
model Chapter {
  id           String            @id @default(cuid())
  novelId      String
  novel        Novel             @relation(fields: [novelId], references: [id], onDelete: Cascade)
  title        String
  content      String            @default("") // 章节内容（本地存储的简短内容）
  contentOss   String?           // 章节内容OSS路径
  wordCount    Int               @default(0) // 章节字数
  order        Int               @default(0) // 章节顺序
  isPublished  Boolean           @default(false) // 是否发布
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  revisions    ChapterRevision[] // 版本历史

  @@index([novelId])
  @@map("chapters")
}

// 章节版本历史表 (P2-2: 章节卡版本化)
model ChapterRevision {
  id          String   @id @default(cuid())
  chapterId   String
  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  content     String   // 修改前的内容
  wordCount   Int      // 修改前的字数
  source      String   // 修改来源: 'ai_rewrite', 'ai_continue', 'ai_describe', 'manual', etc.
  metadata    String?  // JSON 字符串，存储额外信息（如 AI 动作参数）
  createdAt   DateTime @default(now())

  @@index([chapterId])
  @@map("chapter_revisions")
}

// 角色表
model Character {
  id          String   @id @default(cuid())
  novelId     String
  novel       Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  name        String   // 角色名
  description String?  // 角色描述
  avatar      String?  // 角色头像
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([novelId])
  @@map("characters")
}

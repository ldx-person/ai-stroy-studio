# 环境变量配置模板
# 复制此文件为 .env.local 或 .env.production 并填入实际值

# 数据库配置（仅存章节修订、后台任务；作品正文在 OSS）
DATABASE_URL="file:./prisma/db/custom.db"

# 阿里云OSS配置
OSS_REGION=oss-cn-beijing
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET=your-bucket-name

# ---------- 大模型（三选一，优先级：Z.AI > 阿里云百炼 > 智谱）----------
# 仅配 ALIYUN_AI_API_KEY 时，会自动使用下方 DashScope 兼容地址与 qwen 系列模型，勿再默认走 Z.AI。

# Z.AI（GLM 等）
# ZAI_API_KEY=
# ZAI_MODEL=glm-5-turbo
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# 阿里云百炼（DashScope OpenAI 兼容模式）
ALIYUN_AI_API_KEY=your-api-key
ALIYUN_AI_MODEL=qwen-turbo
ALIYUN_AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 智谱（可选）
# ZHIPU_AI_API_KEY=
# ZHIPU_AI_MODEL=glm-4-flash
# ZHIPU_AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
